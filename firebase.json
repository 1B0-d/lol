{
  "firestore": {
    "database": "(default)",
    "location": "eur3",
    "rules": "firebase/config/firestore.rules",
    "indexes": "firebase/config/firestore.indexes.json"
  },
  "database": {
    "rules": "firebase/config/database.rules.json"
  },
  "auth": {
    "providers": {}
  },
  "hosting": {
    "public": "frontend/public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "cleanUrls": true,
    "rewrites": [
      { "source": "/ru", "destination": "/index_ru.html" },
      { "source": "/auth/ru", "destination": "/auth_ru.html" },
      { "source": "/dashboard/ru", "destination": "/dashboard_ru.html" }
    ]
  }
}
